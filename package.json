{
  "name": "ai_testers",
  "version": "1.0.0",
  "description": "This repository is being turned into a Node.js project built with [Remotion](https://www.remotion.dev/docs/) for code-driven educational video generation.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "sync:data": "node scripts/generate-lesson-data.mjs && node scripts/generate-diagrams.mjs",
    "sync:assets": "mkdir -p public && cp L1/L1_intro.mp4 public/L1_intro.mp4",
    "studio": "npm run sync:assets && npm run sync:data && remotion studio src/index.ts",
    "render:l1": "node scripts/prepare-and-render-enhanced.mjs",
    "render:l1-enhanced": "node scripts/prepare-and-render-enhanced.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@remotion/cli": "^4.0.436",
    "@terrastruct/d2": "^0.1.33",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.436"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
