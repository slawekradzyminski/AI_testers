{
  "name": "ai_testers",
  "version": "1.0.0",
  "description": "This repository is being turned into a Node.js project built with [Remotion](https://www.remotion.dev/docs/) for code-driven educational video generation.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "sync:assets": "mkdir -p public && cp L5/attention.mp4 public/L5_attention.mp4",
    "sync:assets:l5": "mkdir -p public && cp L5/attention.mp4 public/L5_attention.mp4",
    "studio": "npm run sync:assets && remotion studio src/index.ts",
    "studio:l5": "npm run sync:assets:l5 && remotion studio src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@remotion/cli": "^4.0.436",
    "@terrastruct/d2": "^0.1.33",
    "dotenv": "^17.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.436"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
